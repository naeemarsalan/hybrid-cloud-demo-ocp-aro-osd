# Template — do NOT commit with real credentials.
# Copy this file, fill in the token, and apply manually:
#   cp git-secret.yaml.template git-secret.yaml
#   # Edit git-secret.yaml with your GitHub PAT
#   oc apply -f git-secret.yaml
#
# Or use scripts/00-setup-git-secret.sh to create it interactively.
apiVersion: v1
kind: Secret
metadata:
  name: git-credentials
  namespace: online-boutique
type: Opaque
stringData:
  user: git
  accessToken: <GITHUB_PAT_HERE>
